<Styles
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border
          Classes="container-product"
          Width="50" Height="50"
          Margin="20" />
    </Design.PreviewWith>

    <Style Selector="Border.container">
        <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="Background" Value="{StaticResource Gray750}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="{StaticResource Gray750}" />
    </Style>

    <Style Selector="Border.container-product">
        <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="Background" Value="{StaticResource Gray700}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="{StaticResource Gray700}" />
    </Style>
</Styles>