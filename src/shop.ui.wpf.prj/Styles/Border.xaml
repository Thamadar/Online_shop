<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="container" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Gray750}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteMain}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Margin" Value="8" />
    </Style>

    <Style x:Key="container-product" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Gray750}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteMain}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="{DynamicResource ButtonCornerRadius}" />
        <Setter Property="Margin" Value="8" />
    </Style>
</ResourceDictionary>