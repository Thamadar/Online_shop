<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Shop.UI.WPF.Controls" xmlns:converters="clr-namespace:Shop.UI.WPF.Converters">

    <Style TargetType="{x:Type controls:ButtonIcon}">
        <Setter Property="Background" Value="{StaticResource Gray700}" />
        <Setter Property="BorderBrush" Value="{StaticResource WhiteMain}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WhiteMain}" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="MinWidth" Value="45" />
        <Setter Property="Padding" Value="10,1,10,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate
                    TargetType="{x:Type controls:ButtonIcon}">
                    <Border
                        x:Name="PART_MainBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource ButtonCornerRadius}">
                        <Grid
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition
                                    Width="Auto" />
                                <ColumnDefinition
                                    Width="*" />
                            </Grid.ColumnDefinitions>

                            <ContentControl
                                x:Name="PART_IconContentControl"
                                Grid.Column="0"
                                Width="{TemplateBinding IconWidth}"
                                Height="{TemplateBinding IconHeight}"
                                MinWidth="{TemplateBinding IconWidth}"
                                MinHeight="{TemplateBinding IconHeight}"
                                Margin="-1,-1,0,0"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                Template="{TemplateBinding IconContent}" />
                            <TextBlock
                                x:Name="PART_TextTextBlock"
                                Grid.Column="1"
                                Margin="7,-2,0,0"
                                Text="{TemplateBinding TextButton}"
                                FontWeight="{TemplateBinding FontWeight}"
                                Foreground="{TemplateBinding Foreground}"
                                Style="{DynamicResource textblock-default}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>

                        <!-- Triggers default -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{DynamicResource Gray650}" />
                            <Setter Property="Cursor" Value="Hand" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{DynamicResource Gray750}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{DynamicResource Gray200}" />
                            <Setter Property="Foreground" Value="{DynamicResource Gray100}" />
                        </Trigger>

                        <!-- Triggers IsRed -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource Red600}" />
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource WhiteMain}" />
                        </MultiTrigger>

                        <!-- MultiTrigger IsRed для IsMouseOver -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource Red550}" />
                            <Setter Property="Cursor" Value="Hand" />
                        </MultiTrigger>

                        <!-- MultiTrigger IsRed для IsPressed -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource Red650}" />
                        </MultiTrigger>

                        <!-- MultiTrigger IsRed для IsEnabled -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource RedGray}" />
                            <Setter Property="Foreground" Value="{DynamicResource Gray100}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Short -->
    <Style x:Key="IsShortSizeStyle" BasedOn="{StaticResource {x:Type controls:ButtonIcon}}" TargetType="{x:Type controls:ButtonIcon}">
        <Setter Property="MaxHeight" Value="44" />
        <Setter Property="MinWidth" Value="45" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate
                    TargetType="{x:Type controls:ButtonIcon}">
                    <Border
                        x:Name="PART_MainBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource ButtonCornerRadius}">
                        <Grid
                            Margin="{TemplateBinding Padding}">
                            <ContentControl
                                x:Name="PART_IconContentControl"
                                Width="{TemplateBinding IconWidth}"
                                Height="{TemplateBinding IconHeight}"
                                MinWidth="{TemplateBinding IconWidth}"
                                MinHeight="{TemplateBinding IconHeight}"
                                Margin="-1,-1,0,0"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                Template="{TemplateBinding IconContent}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>

                        <!-- Triggers default -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{DynamicResource Gray650}" />
                            <Setter Property="Cursor" Value="Hand" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{DynamicResource Gray750}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{DynamicResource Gray200}" />
                            <Setter Property="Foreground" Value="{DynamicResource Gray100}" />
                        </Trigger>

                        <!-- Triggers IsRed -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource Red600}" />
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource WhiteMain}" />
                        </MultiTrigger>

                        <!-- MultiTrigger IsRed для IsMouseOver -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource Red550}" />
                            <Setter Property="Cursor" Value="Hand" />
                        </MultiTrigger>

                        <!-- MultiTrigger IsRed для IsPressed -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource Red650}" />
                        </MultiTrigger>

                        <!-- MultiTrigger IsRed для IsEnabled -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsRed" Value="True" />
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_MainBorder" Property="Background" Value="{StaticResource RedGray}" />
                            <Setter Property="Foreground" Value="{DynamicResource Gray100}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>